

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id Int @id @default(autoincrement())
  title String
  content String
  readtime String
  author String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

